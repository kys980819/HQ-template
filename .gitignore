.DS_Store
Thumbs.db
*.log
*.tmp
.env
.env.*
node_modules/

# 옵시디언 휘발 파일 (기기별 상태 — 동기화 대상 아님)
brain/.obsidian/workspace.json
brain/.obsidian/workspace-mobile.json
brain/.obsidian/cache/

# 클로드코드 로컬 설정
.claude/settings.local.json

# HQ 루트를 실수로 볼트로 열었을 때 생기는 잔여물 (진짜 볼트는 brain/)
/.obsidian/

# --- 발행 백업 방어 (2026-07-09) ---
# 공개 배포판(HQ-template)에는 개인 노트만 쌓이는 아래 폴더의 실제 내용이 들어오면 안 된다.
# 발행 스크립트가 이 폴더들을 복사하지 않는 게 1차 방어선이고, 이 규칙은 실수로
# 개인 데이터가 들어와도 git이 못 올리게 막는 2차 방어선이다.
# 폴더 골격 유지를 위한 스타터 .gitkeep은 예외로 남긴다.
# (주의: brain/프로필.md는 빈 양식이 배포돼야 하므로 여기서 ignore하지 않는다.)
brain/90-Daily/*
!brain/90-Daily/.gitkeep
brain/50-프로젝트/*
!brain/50-프로젝트/.gitkeep
brain/91-첨부/*
!brain/91-첨부/.gitkeep
brain/99-Archive/*
!brain/99-Archive/.gitkeep
# 01-Wiki는 하위 폴더마다 .gitkeep이 있어 재귀 패턴을 쓴다
brain/01-Wiki/**
!brain/01-Wiki/**/
!brain/01-Wiki/**/.gitkeep
